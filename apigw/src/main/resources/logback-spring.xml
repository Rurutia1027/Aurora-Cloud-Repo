<configuration>

    <include resource="org/springframework/boot/logging/logback/defaults.xml"/>

    <!-- Console appender with JSON encoder including MDC (traceId/spanId from OpenTelemetry) -->
    <appender name="STDOUT" class="ch.qos.logback.core.ConsoleAppender">
        <encoder class="net.logstash.logback.encoder.LoggingEventCompositeJsonEncoder">
            <providers>
                <timestamp/>
                <logLevel/>
                <loggerName/>
                <threadName/>
                <message/>
                <context/>
                <!-- MDC fields: expect OpenTelemetry Java Agent to populate trace_id/span_id -->
                <mdc/>
                <arguments/>
                <stackTrace/>
            </providers>
        </encoder>
    </appender>

    <root level="${LOG_LEVEL:-INFO}">
        <appender-ref ref="STDOUT"/>
    </root>

</configuration>

